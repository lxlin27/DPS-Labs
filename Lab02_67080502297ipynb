        "# Hint: ใช้คำสั่ง np.fft.rfft() กับตัวแปรข้อมูลเสียง\n",
        "fft_values = np.fft.rfft(data)\n",
        "# หาค่าขนาด (Magnitude) โดยใช้ค่าสัมบูรณ์ (Absolute value)\n",
        "magnitude = np.abs(fft_values)\n",
